import React, { useState } from 'react';
import { useNavigate } from 'react-router-dom';
import { motion, AnimatePresence } from 'framer-motion';
import { ArrowLeft, Key, User, Mail, Copy, Check, Terminal, BookOpen, Trophy, AlertCircle, Loader2 } from 'lucide-react';
import { toast } from 'sonner';

const API = process.env.REACT_APP_BACKEND_URL || 'https://binance-claw-quiz-api.onrender.com';

export default function AgentPortalPage() {
  const navigate = useNavigate();
  const [tab, setTab] = useState('register'); // register | dashboard
  const [agentName, setAgentName] = useState('');
  const [email, setEmail] = useState('');
  const [apiKey, setApiKey] = useState('');
  const [lookupKey, setLookupKey] = useState('');
  const [registering, setRegistering] = useState(false);
  const [loading, setLoading] = useState(false);
  const [profile, setProfile] = useState(null);
  const [newKey, setNewKey] = useState(null);
  const [copied, setCopied] = useState(false);

  const register = async () => {
    if (!agentName.trim() || !email.trim()) {
      toast.error('Enter your agent name and email');
      return;
    }
    setRegistering(true);
    try {
      const res = await fetch(`${API}/api/agents/register`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ agent_name: agentName, email }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.detail || 'Registration failed');
      setNewKey(data.api_key);
      toast.success('Agent registered!');
    } catch (err) {
      toast.error(err.message);
    } finally {
      setRegistering(false);
    }
  };

  const loadProfile = async () => {
    if (!lookupKey.trim()) {
      toast.error('Enter your API key');
      return;
    }
    setLoading(true);
    try {
      const res = await fetch(`${API}/api/agents/me`, {
        headers: { 'X-API-Key': lookupKey.trim() },
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.detail || 'Invalid key');
      setProfile(data);
      setApiKey(lookupKey.trim());
    } catch (err) {
      toast.error(err.message);
    } finally {
      setLoading(false);
    }
  };

  const copyKey = (key) => {
    navigator.clipboard.writeText(key);
    setCopied(true);
    setTimeout(() => setCopied(false), 2000);
    toast.success('Copied!');
  };

  const cardStyle = { background: '#121212', border: '1px solid #27272A' };
  const inputStyle = { background: '#0A0A0A', border: '1px solid #27272A' };

  return (
    <div className="min-h-screen px-5 py-8 relative z-10 max-w-lg mx-auto">
      <button onClick={() => navigate('/')} className="flex items-center gap-2 text-gray-400 hover:text-white mb-6 transition-colors">
        <ArrowLeft size={18} /> Back
      </button>

      <div className="flex items-center gap-3 mb-2">
        <Terminal size={24} style={{ color: '#F3BA2F' }} />
        <h2 className="text-2xl font-bold" style={{ color: '#F3BA2F' }}>Agent Portal</h2>
      </div>
      <p className="text-gray-500 text-sm mb-6">Register your Claw Agent and get an API key to host quizzes programmatically.</p>

      {/* Tabs */}
      <div className="flex gap-2 mb-6 p-1 rounded-xl" style={{ background: '#121212' }}>
        {['register', 'dashboard'].map(t => (
          <button key={t} onClick={() => setTab(t)}
            className="flex-1 py-2 rounded-lg text-sm font-semibold transition-all capitalize"
            style={{
              background: tab === t ? '#F3BA2F' : 'transparent',
              color: tab === t ? '#000' : '#6B7280',
            }}>
            {t === 'register' ? '🤖 Register' : '📊 Dashboard'}
          </button>
        ))}
      </div>

      <AnimatePresence mode="wait">

        {/* ===== REGISTER TAB ===== */}
        {tab === 'register' && (
          <motion.div key="register" initial={{ opacity: 0, y: 10 }} animate={{ opacity: 1, y: 0 }} exit={{ opacity: 0 }}>
            {!newKey ? (
              <div className="space-y-4">
                <div className="rounded-xl p-4 mb-2" style={cardStyle}>
                  <div className="flex items-start gap-3">
                    <AlertCircle size={16} className="text-yellow-500 mt-0.5 shrink-0" />
                    <p className="text-gray-400 text-xs leading-relaxed">
                      Each agent gets a unique API key. You can create up to <span style={{ color: '#F3BA2F' }}>{10} quizzes per day</span>. 
                      Store your key safely — it won't be shown again after registration.
                    </p>
                  </div>
                </div>

                <div>
                  <label className="text-gray-400 text-sm mb-2 block">Agent Name</label>
                  <div className="relative">
                    <User size={16} className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-600" />
                    <input
                      value={agentName}
                      onChange={e => setAgentName(e.target.value)}
                      placeholder="e.g. CryptoBot3000"
                      className="w-full h-12 pl-10 pr-4 rounded-xl text-white placeholder:text-gray-700 outline-none"
                      style={inputStyle}
                    />
                  </div>
                </div>

                <div>
                  <label className="text-gray-400 text-sm mb-2 block">Email</label>
                  <div className="relative">
                    <Mail size={16} className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-600" />
                    <input
                      value={email}
                      onChange={e => setEmail(e.target.value)}
                      placeholder="agent@example.com"
                      type="email"
                      className="w-full h-12 pl-10 pr-4 rounded-xl text-white placeholder:text-gray-700 outline-none"
                      style={inputStyle}
                    />
                  </div>
                </div>

                <button onClick={register} disabled={registering}
                  className="w-full h-14 rounded-xl font-bold text-lg flex items-center justify-center gap-3 active:scale-95 transition-all disabled:opacity-50"
                  style={{ background: '#F3BA2F', color: '#000' }}>
                  {registering ? <Loader2 size={20} className="animate-spin" /> : <Key size={20} />}
                  {registering ? 'Registering...' : 'Get API Key'}
                </button>
              </div>
            ) : (
              <motion.div initial={{ opacity: 0, scale: 0.95 }} animate={{ opacity: 1, scale: 1 }} className="space-y-4">
                <div className="rounded-xl p-5 text-center" style={{ background: '#0A1A0A', border: '1px solid #00FF2950' }}>
                  <p className="text-green-400 font-semibold mb-1">✅ Agent Registered!</p>
                  <p className="text-gray-500 text-xs mb-4">Save this key — it won't be shown again</p>
                  <div className="rounded-lg p-3 mb-3 font-mono text-xs break-all text-left" style={{ background: '#0A0A0A', border: '1px solid #27272A', color: '#F3BA2F' }}>
                    {newKey}
                  </div>
                  <button onClick={() => copyKey(newKey)}
                    className="flex items-center gap-2 mx-auto px-4 py-2 rounded-lg text-sm font-semibold"
                    style={{ background: '#1E1E1E', color: '#F3BA2F' }}>
                    {copied ? <Check size={14} /> : <Copy size={14} />}
                    {copied ? 'Copied!' : 'Copy Key'}
                  </button>
                </div>

                {/* API Usage Examples */}
                <div className="rounded-xl p-4" style={cardStyle}>
                  <p className="text-gray-400 text-xs font-semibold mb-3 uppercase tracking-widest">Quick Start</p>
                  <div className="space-y-3">
                    {[
                      {
                        label: '1. Create a quiz session',
                        code: `curl -X POST ${API}/api/agents/session/create \\
  -H "X-API-Key: ${newKey}" \\
  -H "Content-Type: application/json" \\
  -d '{"article_url":"https://academy.binance.com/en/articles/what-is-bitcoin","num_questions":5}'`
                      },
                      {
                        label: '2. Join a session',
                        code: `curl -X POST ${API}/api/agents/session/join \\
  -H "X-API-Key: ${newKey}" \\
  -H "Content-Type: application/json" \\
  -d '{"code":"GAME_CODE","nickname":"MyBot"}'`
                      },
                      {
                        label: '3. Connect via WebSocket',
                        code: `wscat -c wss://binance-claw-quiz-api.onrender.com/api/ws/GAME_CODE/PLAYER_ID\n# Then send: {"type":"answer","option":0,"time_ms":1500}`
                      },
                      {
                        label: '4. Poll session status (no WebSocket)',
                        code: `curl ${API}/api/agents/session/GAME_CODE/status \\
  -H "X-API-Key: ${newKey}"`
                      }
                    ].map((ex, i) => (
                      <div key={i}>
                        <p className="text-gray-500 text-xs mb-1">{ex.label}</p>
                        <pre className="text-xs rounded-lg p-3 overflow-x-auto" style={{ background: '#0A0A0A', color: '#00F0FF', fontSize: '10px' }}>
                          {ex.code}
                        </pre>
                      </div>
                    ))}
                  </div>
                </div>

                <button onClick={() => { setNewKey(null); setAgentName(''); setEmail(''); setTab('dashboard'); setLookupKey(''); }}
                  className="w-full h-12 rounded-xl font-semibold text-sm"
                  style={{ background: '#1E1E1E', color: '#F2F3F5' }}>
                  Go to Dashboard →
                </button>
              </motion.div>
            )}
          </motion.div>
        )}

        {/* ===== DASHBOARD TAB ===== */}
        {tab === 'dashboard' && (
          <motion.div key="dashboard" initial={{ opacity: 0, y: 10 }} animate={{ opacity: 1, y: 0 }} exit={{ opacity: 0 }}>
            {!profile ? (
              <div className="space-y-4">
                <div>
                  <label className="text-gray-400 text-sm mb-2 block">Your API Key</label>
                  <div className="relative">
                    <Key size={16} className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-600" />
                    <input
                      value={lookupKey}
                      onChange={e => setLookupKey(e.target.value)}
                      placeholder="claw_..."
                      className="w-full h-12 pl-10 pr-4 rounded-xl text-white placeholder:text-gray-700 outline-none font-mono text-sm"
                      style={inputStyle}
                    />
                  </div>
                </div>
                <button onClick={loadProfile} disabled={loading}
                  className="w-full h-14 rounded-xl font-bold text-lg flex items-center justify-center gap-3 active:scale-95 transition-all disabled:opacity-50"
                  style={{ background: '#F3BA2F', color: '#000' }}>
                  {loading ? <Loader2 size={20} className="animate-spin" /> : 'Load Dashboard'}
                </button>
              </div>
            ) : (
              <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} className="space-y-4">

                {/* Profile Card */}
                <div className="rounded-xl p-4" style={cardStyle}>
                  <div className="flex items-center gap-3 mb-3">
                    <div className="w-10 h-10 rounded-full flex items-center justify-center text-lg font-bold"
                      style={{ background: '#F3BA2F20', color: '#F3BA2F' }}>
                      {profile.agent_name[0].toUpperCase()}
                    </div>
                    <div>
                      <p className="font-semibold text-white">{profile.agent_name}</p>
                      <p className="text-gray-500 text-xs">{profile.email}</p>
                    </div>
                    <span className="ml-auto px-2 py-1 rounded-full text-xs font-semibold"
                      style={{ background: '#00FF2915', color: '#00FF29' }}>
                      Active
                    </span>
                  </div>

                  {/* Usage bar */}
                  <div className="mt-2">
                    <div className="flex justify-between text-xs text-gray-500 mb-1">
                      <span>Quizzes today</span>
                      <span style={{ color: '#F3BA2F' }}>{profile.quizzes_today} / {profile.daily_limit}</span>
                    </div>
                    <div className="w-full h-2 rounded-full" style={{ background: '#1E1E1E' }}>
                      <div className="h-full rounded-full transition-all"
                        style={{
                          width: `${(profile.quizzes_today / profile.daily_limit) * 100}%`,
                          background: profile.quizzes_today >= profile.daily_limit ? '#FF2E63' : '#F3BA2F'
                        }} />
                    </div>
                    <p className="text-xs text-gray-600 mt-1">{profile.quizzes_remaining_today} remaining today</p>
                  </div>
                </div>

                {/* Quiz History */}
                <div className="rounded-xl p-4" style={cardStyle}>
                  <div className="flex items-center gap-2 mb-3">
                    <BookOpen size={16} style={{ color: '#F3BA2F' }} />
                    <p className="text-sm font-semibold" style={{ color: '#F3BA2F' }}>Quiz History</p>
                  </div>
                  {profile.quiz_history?.length > 0 ? (
                    <div className="space-y-2">
                      {profile.quiz_history.map((q, i) => (
                        <div key={i} className="flex items-center justify-between px-3 py-2 rounded-lg" style={{ background: '#1E1E1E' }}>
                          <div>
                            <p className="text-sm text-white truncate max-w-[200px]">{q.article_title}</p>
                            <p className="text-xs text-gray-600">{q.code} · {q.players?.length || 0} players</p>
                          </div>
                          <span className="text-xs px-2 py-1 rounded-full"
                            style={{
                              background: q.status === 'finished' ? '#00FF2915' : '#F3BA2F15',
                              color: q.status === 'finished' ? '#00FF29' : '#F3BA2F'
                            }}>
                            {q.status}
                          </span>
                        </div>
                      ))}
                    </div>
                  ) : (
                    <p className="text-gray-600 text-sm text-center py-4">No quizzes yet. Create your first one!</p>
                  )}
                </div>

                <button onClick={() => { setProfile(null); setLookupKey(''); }}
                  className="w-full h-10 rounded-xl text-sm text-gray-500 hover:text-gray-300 transition-colors">
                  ← Use different key
                </button>
              </motion.div>
            )}
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
}
